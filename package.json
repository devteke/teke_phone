{
  "name": "teke_phone",
  "version": "0.1.0",
  "private": true,
  "description": "FiveM telefon scripti - qbx_core, TypeScript backend, React NUI",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "build:web": "npm --prefix web run build",
    "dev:web": "npm --prefix web run dev",
    "build:all": "npm run build && npm run build:web",
    "typecheck": "tsc --noEmit -p src/server/tsconfig.json && tsc --noEmit -p src/client/tsconfig.json"
  },
  "devDependencies": {
    "@citizenfx/client": "^2.0.31725-1",
    "@citizenfx/server": "^2.0.31689-1",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@overextended/ox_lib": "^3.37.0"
  }
}